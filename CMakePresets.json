{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Linux Debug",
            "description": "Configure a local Linux debug build in build-debug.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Linux Release",
            "description": "Configure a local Linux release build in build-release.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "mingw-debug",
            "displayName": "MSYS2 MinGW64 Debug",
            "description": "Configure a Windows MinGW64 debug build using tools available in PATH.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "mingw-release",
            "displayName": "MSYS2 MinGW64 Release",
            "description": "Configure a Windows MinGW64 release build using tools available in PATH.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "msvc-vs2026",
            "displayName": "MSVC VS2026 x64",
            "description": "Configure a Windows MSVC build with Visual Studio 2026 in build-msvc.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build-msvc"
        },
        {
            "name": "macos-debug",
            "displayName": "macOS Debug",
            "description": "Configure a local macOS debug build in build-mac-debug.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-mac-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_PREFIX_PATH": "/opt/homebrew;/usr/local"
            }
        },
        {
            "name": "macos-release",
            "displayName": "macOS Release",
            "description": "Configure a local macOS release build in build-mac-release.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-mac-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "/opt/homebrew;/usr/local"
            }
        },
        {
            "name": "Configure preset using toolchain file",
            "displayName": "Configure preset using toolchain file",
            "description": "Sets Ninja generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Linux Debug",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build Linux Release",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "configurePreset": "release"
        },
        {
            "name": "build-mingw-debug",
            "displayName": "Build MSYS2 MinGW64 Debug",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "configurePreset": "mingw-debug"
        },
        {
            "name": "build-mingw-release",
            "displayName": "Build MSYS2 MinGW64 Release",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "configurePreset": "mingw-release"
        },
        {
            "name": "build-msvc-debug",
            "displayName": "Build MSVC Debug",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "configurePreset": "msvc-vs2026",
            "configuration": "Debug"
        },
        {
            "name": "build-msvc-release",
            "displayName": "Build MSVC Release",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "configurePreset": "msvc-vs2026",
            "configuration": "Release"
        },
        {
            "name": "build-macos-debug",
            "displayName": "Build macOS Debug",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "configurePreset": "macos-debug"
        },
        {
            "name": "build-macos-release",
            "displayName": "Build macOS Release",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "configurePreset": "macos-release"
        }
    ]
}