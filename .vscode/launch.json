{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug my_app",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/my_app",
      "args": ["TestInputFiles/sample.sph"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        { "description": "Enable pretty-printing", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "build",
      "logging": { "engineLogging": false }
    }
  ]
}