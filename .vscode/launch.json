{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug cvt",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/cvt",
      "args": ["TestInputFiles/bigsnap.sph"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "linux": {
        "miDebuggerPath": "/usr/bin/gdb"
      },
      "windows": {
        "program": "${workspaceFolder}/build-debug/cvt.exe",
        "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
        "environment": [
          { "name": "PATH", "value": "C:/msys64/mingw64/bin;${env:PATH}" }
        ]
      },
      "setupCommands": [
        { "description": "Enable pretty-printing", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "preLaunchTask": "build-debug",
      "logging": { "engineLogging": false }
    }
  ]
}