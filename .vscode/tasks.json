{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure-debug",
      "type": "shell",
      "command": "cmake --preset debug",
      "windows": {
        "command": "cmake --preset mingw-debug"
      },
      "problemMatcher": [],
      "detail": "Configure the Debug build directory"
    },
    {
      "label": "build-debug",
      "type": "shell",
      "command": "cmake --build --preset debug",
      "windows": {
        "command": "cmake --build --preset build-mingw-debug"
      },
      "group": "build",
      "problemMatcher": ["$gcc"],
      "dependsOn": ["configure-debug"],
      "detail": "Build the Debug configuration"
    },
    {
      "label": "configure-release",
      "type": "shell",
      "command": "cmake --preset release",
      "windows": {
        "command": "cmake --preset mingw-release"
      },
      "problemMatcher": [],
      "detail": "Configure the Release build directory"
    },
    {
      "label": "build-release",
      "type": "shell",
      "command": "cmake --build --preset release",
      "windows": {
        "command": "cmake --build --preset build-mingw-release"
      },
      "problemMatcher": ["$gcc"],
      "dependsOn": ["configure-release"],
      "detail": "Build the Release configuration"
    }
  ]
}